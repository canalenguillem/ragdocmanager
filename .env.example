# API
NODE_ENV=development
PORT=4000
JWT_SECRET=change_me_to_random_256bit_string

# MariaDB
MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_DATABASE=ragdocs
MARIADB_USER=raguser
MARIADB_PASSWORD=ragpass
MARIADB_ROOT_PASSWORD=rootpass

# MongoDB
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE=ragdocs
MONGO_USER=raguser
MONGO_PASSWORD=ragpass

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispass

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_docs

# Google Gemini (embeddings) — fallback/admin default only
GEMINI_API_KEY=AIza...
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-0

# OpenAI (chat LLM) — fallback/admin default only
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o

# Encryption key for API keys stored in DB (32 bytes hex)
API_KEY_ENCRYPTION_SECRET=change_me_to_64_hex_chars_random

# n8n
N8N_USER=admin
N8N_PASSWORD=n8npass

# Upload
MAX_FILE_SIZE_MB=50
UPLOADS_PATH=/app/uploads
